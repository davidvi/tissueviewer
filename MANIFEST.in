include README.md
include LICENSE.md
include MIGRATION.md
include CONTRIBUTING.md
include pyproject.toml

recursive-include src/tissueviewer/web *

# Never ship these.
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
prune feature-overlay
prune cloud-deploy
prune client
prune publication
prune img
prune tests
